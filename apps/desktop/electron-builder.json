{
  "appId": "com.jamo.studio",
  "productName": "Jamo Studio",
  "directories": {
    "output": "out"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../../proto",
      "to": "proto",
      "filter": ["**/*.proto"]
    },
    {
      "from": "bin/jamo-engine",
      "to": "bin/jamo-engine"
    }
  ],
  "mac": {
    "target": [
      { "target": "dmg", "arch": ["x64", "arm64"] },
      { "target": "zip", "arch": ["x64", "arm64"] }
    ],
    "icon": "assets/icon.icns",
    "category": "public.app-category.developer-tools"
  },
  "linux": {
    "target": [
      { "target": "AppImage", "arch": ["x64", "arm64"] },
      { "target": "deb", "arch": ["x64", "arm64"] }
    ],
    "icon": "assets/icon.png",
    "category": "Development"
  },
  "publish": {
    "provider": "github",
    "owner": "jamohq",
    "repo": "studio"
  }
}
