{
  "name": "jamo-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -n tsc,vite,electron \"tsc -p tsconfig.main.json --watch\" \"vite\" \"wait-on file:dist/main/index.js http://localhost:5173 && electron .\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@grpc/grpc-js": "^1.12.5",
    "@grpc/proto-loader": "^0.7.13",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.3"
  }
}
